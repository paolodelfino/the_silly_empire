    "prod__w": "bun x dotenv-cli -e prod.env -- cmd /C 'next start -p %WEB_PORT%'",
    "prod__w:proxy": "bun x dotenv-cli -e prod.env -- cmd /C 'local-ssl-proxy --source %WEB_PROXY_PORT% --target %WEB_PORT%'",
    "lint": "next lint",
    "test": "bun x dotenv-cli -e dev.env -- cmd /C 'bun run test/test.ts",
    "ts": "tsc --noEmit"
  },
